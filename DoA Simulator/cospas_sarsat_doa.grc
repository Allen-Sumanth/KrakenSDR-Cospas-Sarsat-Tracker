    dimension: '1'
    in_type: byte
    maxoutbuf: '0'
    minoutbuf: '0'
    num_ports: '1'
    out_type: float
    symbol_table: '[1,-1]'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [240, 340]
    rotation: 0
    state: enabled
- name: pad_sink_0
